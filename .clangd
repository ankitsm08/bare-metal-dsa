---
CompileFlags:
  Add:
    - -Wall
    - -Wextra
    - -Wpedantic
    - -Wconversion
    - -Wno-sign-conversion
    - -Wshadow
    - -Wdouble-promotion
    - -Wnull-dereference

    - -fsanitize=address
    - -fsanitize=undefined

Diagnostics:
  UnusedIncludes: Strict

  ClangTidy:
    Add:
      - performance-*
      - modernize-*
    Remove:
      - modernize-use-trailing-return-type

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  Designators: Yes
...
---
If:
  PathMatch: .*\.(c|h)

CompileFlags:
  Add:
    - -std=c11
...
---
If:
  PathMatch: .*\.(cpp|hpp|cxx|cc)

CompileFlags:
  Add:
    - -std=c++20
    - -Wnon-virtual-dtor
    - -Wold-style-cast
...
